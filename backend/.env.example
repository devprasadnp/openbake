# ─── OpenBake Backend — Environment Variables ────────────────────────────────
# Copy this file to .env and fill in every value before deploying.
# NEVER commit the real .env to version control.

# ── App ────────────────────────────────────────────────────────────────────────
APP_ENV=production                         # development | production
SECRET_KEY=REPLACE_WITH_64_CHAR_RANDOM_HEX # python -c "import secrets; print(secrets.token_hex(32))"
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── CORS (comma-separated list of allowed origins) ────────────────────────────
ALLOWED_ORIGINS=https://openbake.in,https://www.openbake.in

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://bakery_user:STRONG_PASSWORD@db:5432/bakery_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Firebase (path inside container) ─────────────────────────────────────────
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

# ── Cloudinary ────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Razorpay ──────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_xxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# ── PayU ──────────────────────────────────────────────────────────────────────
PAYU_MERCHANT_KEY=your_payu_key
PAYU_MERCHANT_SALT=your_payu_salt
PAYU_CLIENT_ID=your_payu_client_id
PAYU_CLIENT_SECRET=your_payu_client_secret
PAYU_PAYMENT_URL=https://test.payu.in/_payment
PAYU_STATUS_API_URL=https://test.payu.in/merchant/postservice?form=2

# ── Payment Redirect URLs ─────────────────────────────────────────────────────
WEB_BASE_URL=https://openbake.in
ANDROID_DEEP_LINK_BASE=openbake://payment-result

# ── Admin bootstrap (used only by seed.py / first-run) ───────────────────────
ADMIN_EMAIL=admin@openbake.in
ADMIN_PASSWORD=CHANGE_THIS_STRONG_PASSWORD

# ── PostgreSQL (used by docker-compose) ───────────────────────────────────────
POSTGRES_USER=bakery_user
POSTGRES_PASSWORD=STRONG_PASSWORD
POSTGRES_DB=bakery_db
