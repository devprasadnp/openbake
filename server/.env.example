# ─── OpenBake Server — Environment Variables ─────────────────────────────────
# Copy this file to .env and fill in every value before deploying.
# NEVER commit the real .env to version control.

# ── App ────────────────────────────────────────────────────────────────────────
APP_ENV=production                         # development | production
SECRET_KEY=REPLACE_WITH_64_CHAR_RANDOM_HEX # openssl rand -hex 32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── CORS (comma-separated list of allowed origins) ────────────────────────────
ALLOWED_ORIGINS=https://openbake.in,https://www.openbake.in

# ── Database (MySQL) ──────────────────────────────────────────────────────────
DATABASE_URL=jdbc:mysql://db:3306/openbake?useSSL=false&allowPublicKeyRetrieval=true
DATABASE_USERNAME=bakery_user
DATABASE_PASSWORD=STRONG_PASSWORD

# ── Media (avatar upload storage dir) ─────────────────────────────────────────
MEDIA_DIR=/app/media

# ── Firebase (path inside container) ─────────────────────────────────────────
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

# ── PayU ──────────────────────────────────────────────────────────────────────
PAYU_MERCHANT_KEY=your_payu_key
PAYU_MERCHANT_SALT=your_payu_salt
PAYU_CLIENT_ID=your_payu_client_id
PAYU_CLIENT_SECRET=your_payu_client_secret
PAYU_PAYMENT_URL=https://test.payu.in/_payment
PAYU_STATUS_API_URL=https://test.payu.in/merchant/postservice?form=2
PAYU_CALLBACK_BASE_URL=https://openbake.in

# ── Payment Redirect URLs ─────────────────────────────────────────────────────
WEB_BASE_URL=https://openbake.in
ANDROID_DEEP_LINK_BASE=openbake://payment-result

# ── Admin bootstrap (used only by DataSeeder / first-run) ────────────────────
ADMIN_EMAIL=admin@openbake.in
ADMIN_PASSWORD=CHANGE_THIS_STRONG_PASSWORD

# ── MySQL (used by docker-compose) ────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=STRONG_ROOT_PASSWORD
MYSQL_DATABASE=openbake
MYSQL_USER=bakery_user
MYSQL_PASSWORD=STRONG_PASSWORD
